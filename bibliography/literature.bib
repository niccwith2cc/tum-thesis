@mastersthesis{swadiryus_DifferentiableMotionPlanning_2025,
	address = {Munich, Germany},
	title = {Differentiable {Motion} {Planning} for {Autonomous} {Vehicles}},
	abstract = {Differentiable Motion Planning for Autonomous Vehicles
In the AVS lab, we focus on pushing the boundaries of autonomous driving by developing advanced software
modules, ensuring ethical behavior in autonomous systems, and testing algorithms in real-world scenarios
using real vehicles. We work with autonomous vehicles ranging from 1/10th scale race cars to full-scale
autonomous road vehicles, providing a unique and hands-on research environment.
This thesis focuses on developing a differentiable motion planner for F1TENTH autonomous race cars.
Currently, our vehicles follow a predefined raceline without considering feasibility checks or potential collisions.
The new motion planner will sample feasible trajectories, evaluate them based on a cost function that
considers factors like collision risk, control effort, and driving speed, and select the optimal trajectory for safe
and efficient driving.
Differentiable motion planners are unique because they allow gradient-based optimization, integrating the
motion planning process with machine learning algorithms. This enables real-time optimization, resulting in
more adaptive and efficient driving strategies compared to traditional methods. In this thesis, you will apply
these state-of-the-art techniques to autonomous racing, bridging the gap between theoretical algorithms and
practical application.
The following points are to be addressed by Jeremialie K. Swadiryus in the thesis:
• Conduct a literature review on motion planning and differentiable algorithms.
• Develop a differentiable motion planner tailored for F1TENTH race cars.
• Design and implement cost functions to evaluate trajectories based on multiple factors (e.g.,
collision avoidance, control effort, speed).
• Integrate the motion planner within the vehicle’s existing software stack.
• Test and validate the planner in both simulation and real-world environments.
• Benchmark performance against current non-differentiable planning approaches.},
	school = {Technical University of Munich},
	author = {Swadiryus, Jeremialie K.},
	month = jun,
	year = {2025},
	file = {Differentiable Motion Planning for Autonomous Vehicles:/home/thiccnick/Zotero/storage/84NFCKU5/TUM - Differentiable Motion Planning for Autonomous Vehicles.pdf:application/pdf},
}

@mastersthesis{koch_DifferentiableInterpretablePath_2025,
	address = {Munich, Germany},
	title = {Differentiable and {Interpretable} {Path} {Planning} for {Autonomous} {Mobile} {Robots}},
	abstract = {In the AVS lab, we focus on pushing the boundaries of autonomous driving by developing advanced software modules, ensuring ethical behavior in autonomous systems, and testing algorithms in real-world scenarios using real vehicles. We work with autonomous vehicles ranging from 1/10th scale race cars to full-scale autonomous road vehicles, providing a unique and hands-on research environment.
Differentiable modular autonomous driving stacks seek to combine the advantages interpretability and end-to-end (E2E) trainability from model based and data based architectures respectively. The sampling based path planner, a common choice in autonomous driving stacks, however, does not allow for E2E learning yet.
This is because selecting the best candidate trajectory is a discrete, non-differentiable operation, that does not allow a gradient flow from downstream tasks to the learnable parameters. This thesis aims to integrate E2E differentiability into the motion planner and to train it effectively using a downstream loss. At the same time it seeks to maintain the level of interpretability of the planner it is based
upon. The steps include proposing a differentiable sample selection method, designing meaningful and differentiable losses, optimizing the training process and conducting extensive tests.
The following points are to be adressed by Felix Koch in the thesis:
• Conduct a literature survey on (differentiable) motion planning and differentiable stochastic
sample selection methods
• Implement, integrate and evaluate methods for differentiable sample selection
• Design, implement and assess meaningful and differentiable loss functions
• Develop, visualize and interpret the gradient flow through the modules
• Test, optimize and validate the planner and training process in various simulation scenarios
for path-tracking, static obstacle avoidance, and head-to-head racing},
	school = {Technical University of Munich},
	author = {Koch, Felix},
	month = nov,
	year = {2025},
	file = {PDF:/home/thiccnick/Zotero/storage/6IV5W8EB/Koch - 2025 - Differentiable and Interpretable Path Planning for Autonomous Mobile Robots.pdf:application/pdf},
}

@article{rosero_integrating_2024,
	title = {Integrating {Modular} {Pipelines} with {End}-to-{End} {Learning}: {A} {Hybrid} {Approach} for {Robust} and {Reliable} {Autonomous} {Driving} {Systems}},
	volume = {24},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	issn = {1424-8220},
	shorttitle = {Integrating {Modular} {Pipelines} with {End}-to-{End} {Learning}},
	url = {https://www.mdpi.com/1424-8220/24/7/2097},
	doi = {10.3390/s24072097},
	abstract = {Autonomous driving navigation relies on diverse approaches, each with advantages and limitations depending on various factors. For HD maps, modular systems excel, while end-to-end methods dominate mapless scenarios. However, few leverage the strengths of both. This paper innovates by proposing a hybrid architecture that seamlessly integrates modular perception and control modules with data-driven path planning. This innovative design leverages the strengths of both approaches, enabling a clear understanding and debugging of individual components while simultaneously harnessing the learning power of end-to-end approaches. Our proposed architecture achieved first and second place in the 2023 CARLA Autonomous Driving Challenge’s SENSORS and MAP tracks, respectively. These results demonstrate the architecture’s effectiveness in both map-based and mapless navigation. We achieved a driving score of 41.56 and the highest route completion of 86.03 in the MAP track of the CARLA Challenge leaderboard 1, and driving scores of 35.36 and 1.23 in the CARLA Challenge SENSOR track with route completions of 85.01 and 9.55, for, respectively, leaderboard 1 and 2. The results of leaderboard 2 raised the hybrid architecture to the first position, winning the edition of the 2023 CARLA Autonomous Driving Competition.},
	language = {en},
	number = {7},
	urldate = {2026-06-09},
	journal = {Sensors},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Rosero, Luis Alberto and Gomes, Iago Pachêco and da Silva, Júnior Anderson Rodrigues and Przewodowski, Carlos André and Wolf, Denis Fernando and Osório, Fernando Santos},
	month = jan,
	year = {2024},
	keywords = {autonomous driving, CARLA simulator, end-to-end, hybrid architecture, modular, path planning},
	pages = {2097},
	file = {Full Text PDF:/home/thiccnick/Zotero/storage/38D8QTNY/Rosero et al. - 2024 - Integrating Modular Pipelines with End-to-End Learning A Hybrid Approach for Robust and Reliable Au.pdf:application/pdf},
}

@misc{chib_recent_2023,
	title = {Recent {Advancements} in {End}-to-{End} {Autonomous} {Driving} using {Deep} {Learning}: {A} {Survey}},
	shorttitle = {Recent {Advancements} in {End}-to-{End} {Autonomous} {Driving} using {Deep} {Learning}},
	url = {http://arxiv.org/abs/2307.04370},
	doi = {10.48550/arXiv.2307.04370},
	abstract = {End-to-End driving is a promising paradigm as it circumvents the drawbacks associated with modular systems, such as their overwhelming complexity and propensity for error propagation. Autonomous driving transcends conventional traffic patterns by proactively recognizing critical events in advance, ensuring passengers' safety and providing them with comfortable transportation, particularly in highly stochastic and variable traffic settings. This paper presents a comprehensive review of the End-to-End autonomous driving stack. It provides a taxonomy of automated driving tasks wherein neural networks have been employed in an End-to-End manner, encompassing the entire driving process from perception to control, while addressing key challenges encountered in real-world applications. Recent developments in End-to-End autonomous driving are analyzed, and research is categorized based on underlying principles, methodologies, and core functionality. These categories encompass sensorial input, main and auxiliary output, learning approaches ranging from imitation to reinforcement learning, and model evaluation techniques. The survey incorporates a detailed discussion of the explainability and safety aspects. Furthermore, it assesses the state-of-the-art, identifies challenges, and explores future possibilities. We maintained the latest advancements and their corresponding open-source implementations at https://github.com/Pranav-chib/Recent-Advancements-in-End-to-End-Autonomous-Driving-using-Deep-Learning.},
	urldate = {2026-06-09},
	publisher = {arXiv},
	author = {Chib, Pranav Singh and Singh, Pravendra},
	month = sep,
	year = {2023},
	note = {arXiv:2307.04370 [cs.RO]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computer Vision and Pattern Recognition, Computer Science - Machine Learning, Computer Science - Robotics},
	file = {Preprint PDF:/home/thiccnick/Zotero/storage/NQBUPTKJ/Chib and Singh - 2023 - Recent Advancements in End-to-End Autonomous Driving using Deep Learning A Survey.pdf:application/pdf;Snapshot:/home/thiccnick/Zotero/storage/6WS7VRZM/2307.html:text/html},
}
